{
    "id": "com.mattermost.plugin-pagerduty",
    "name": "Mattermost PagerDuty Plugin",
    "description": "PagerDuty integration for Mattermost - View on-call schedules and current on-call users directly within Mattermost.",
    "homepage_url": "https://github.com/mattermost/mattermost-plugin-pagerduty",
    "support_url": "https://github.com/mattermost/mattermost-plugin-pagerduty/issues",
    "icon_path": "assets/pagerduty-icon.svg",
    "version": "2.3.0",
    "min_server_version": "10.7.0",
    "server": {
        "executables": {
            "linux-amd64": "server/dist/plugin-linux-amd64",
            "linux-arm64": "server/dist/plugin-linux-arm64",
            "darwin-amd64": "server/dist/plugin-darwin-amd64",
            "darwin-arm64": "server/dist/plugin-darwin-arm64",
            "windows-amd64": "server/dist/plugin-windows-amd64.exe"
        }
    },
    "webapp": {
        "bundle_path": "webapp/dist/main.js"
    },
    "settings_schema": {
        "header": "Configure your PagerDuty integration settings below.",
        "footer": "Need help? Visit our [documentation](https://github.com/mattermost/mattermost-plugin-pagerduty#configuration).",
        "settings": [
            {
                "key": "OAuthClientID",
                "display_name": "PagerDuty OAuth Client ID",
                "type": "text",
                "help_text": "The Client ID from your PagerDuty OAuth application. Create one at https://developer.pagerduty.com/apps.",
                "placeholder": "",
                "default": ""
            },
            {
                "key": "OAuthClientSecret",
                "display_name": "PagerDuty OAuth Client Secret",
                "type": "text",
                "help_text": "The Client Secret from your PagerDuty OAuth application.",
                "placeholder": "",
                "default": "",
                "secret": true
            },
            {
                "key": "APIBaseURL",
                "display_name": "PagerDuty API Base URL",
                "type": "text",
                "help_text": "The base URL for PagerDuty API. Leave default unless using a custom PagerDuty instance.",
                "placeholder": "https://api.pagerduty.com",
                "default": "https://api.pagerduty.com"
            },
            {
                "key": "WebhookSecret",
                "display_name": "Webhook Secret (Optional)",
                "type": "generated",
                "help_text": "Secret used to verify PagerDuty webhook signatures. Auto-generated when using /pagerduty webhook setup. Set manually if configuring webhooks outside the plugin.",
                "placeholder": "",
                "default": ""
            }
        ]
    }
}
